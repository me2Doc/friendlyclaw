# ─────────────────────────────────────────
#  FriendlyClaw Configuration
# ─────────────────────────────────────────

# Platform: telegram | cli
PLATFORM=telegram

# ─────────────────────────────────────────
#  Telegram (required for telegram platform)
# ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ─────────────────────────────────────────
#  Model Provider
#  Options: gemini | openai | openrouter | custom
# ─────────────────────────────────────────
MODEL_PROVIDER=gemini

# Model name (change to whatever model you want)
# Gemini examples:   gemini-2.0-flash | gemini-2.5-pro | gemini-3-pro-preview
# OpenAI examples:   gpt-4o | gpt-4o-mini
# OpenRouter:        google/gemini-pro | anthropic/claude-3-haiku | meta-llama/llama-3.1-8b
MODEL_NAME=gemini-2.0-flash

# ─────────────────────────────────────────
#  API Keys (only fill in what you're using)
# ─────────────────────────────────────────

# Gemini (free at aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI
OPENAI_API_KEY=

# OpenRouter (access to 100+ models, some free)
OPENROUTER_API_KEY=

# Custom OpenAI-compatible endpoint
# e.g. local Ollama, CLIProxyAPI, LM Studio, etc.
CUSTOM_BASE_URL=http://localhost:8317
CUSTOM_API_KEY=fake
